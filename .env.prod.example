# ============================================================
# Production environment — copy to .env.prod and fill in values
# ============================================================

# Caddy site address
# For local verification use :8080 (plain HTTP, no TLS)
# For production use your real domain, e.g.: SITE_DOMAIN=fishmap.ua
SITE_DOMAIN=:8080

# Public origin URL (used in SSR canonical tags, JSON-LD, sitemap)
# For local: SITE_ORIGIN=http://localhost:8080
# For production: SITE_ORIGIN=https://fishmap.ua
SITE_ORIGIN=https://fishmap.ua

# Angular SSR host allowlist (comma-separated; Caddy is the only ingress in prod)
NG_ALLOWED_HOSTS=localhost

# ---- PostgreSQL ----
POSTGRES_USER=fishing
POSTGRES_PASSWORD=change-me
POSTGRES_DB=fishing_db

# Prisma connection string — host must match the compose service name (postgres)
DATABASE_URL=postgresql://fishing:change-me@postgres:5432/fishing_db?schema=public

# ---- Application secrets ----
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-random-secret

# Admin credentials
ADMIN_LOGIN=admin
# Bcrypt hash of the admin password
# Generate with: node -e "const b=require('bcryptjs'); b.hash('yourpassword',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$replace-with-real-bcrypt-hash

# ---- Web / SEO ----
SITE_BASE_URL=https://fishmap.ua

# ---- Seeding ----
# Set to 1 to seed demo waters on first run (dev/staging only)
# In production keep at 0 — run dictionary seed manually if needed
SEED_DEMO=0
