DATABASE_URL="postgresql://fishing:fishing@localhost:5433/fishing_db?schema=public"
# Generate with: openssl rand -hex 32
JWT_SECRET="change-me-long-random-string"
ADMIN_LOGIN="admin"
# Generate with: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" 'your-password'
ADMIN_PASSWORD_HASH=""
# Public site origin — used for sitemap URLs (and CORS if enabled later)
SITE_BASE_URL="http://localhost:4200"
# Set to "1" to seed 3 demo fishing waters — local dev only, never set in production
SEED_DEMO="1"
PORT=3000
